<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_remotly_pull" model="ir.cron">
        <field name="name">Remotly: pull changes</field>
        <field name="model_id" ref="model_remotly_backend"/>
        <field name="state">code</field>
        <field name="code">model.cron_pull()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
